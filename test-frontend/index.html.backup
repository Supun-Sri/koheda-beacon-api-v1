<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kohedha Beacon — Flow Tester</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, -apple-system, sans-serif; background: #111; color: #e0e0e0; padding: 16px; }
    h1 { font-size: 20px; color: #fff; margin-bottom: 8px; }
    h2 { font-size: 15px; color: #aaa; margin-bottom: 16px; font-weight: normal; }
    
    /* Navigation */
    .tabs { display: flex; gap: 4px; margin-bottom: 16px; flex-wrap: wrap; }
    .tab { padding: 8px 14px; background: #222; border: 1px solid #333; border-radius: 6px; cursor: pointer; font-size: 13px; color: #aaa; transition: all 0.15s; }
    .tab:hover { background: #2a2a2a; color: #fff; }
    .tab.active { background: #1a3a5c; border-color: #2a6aaa; color: #5ab4ff; }
    
    /* Panels */
    .panel { display: none; }
    .panel.active { display: block; }
    
    /* Cards */
    .card { background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 8px; padding: 14px; margin-bottom: 10px; }
    .card-title { font-size: 14px; font-weight: 600; color: #fff; margin-bottom: 6px; }
    .card-meta { font-size: 12px; color: #888; }
    .card-meta span { margin-right: 12px; }
    
    /* Forms */
    label { display: block; font-size: 12px; color: #888; margin-bottom: 4px; margin-top: 10px; }
    input, select { width: 100%; padding: 8px; background: #222; border: 1px solid #333; border-radius: 4px; color: #e0e0e0; font-size: 13px; }
    input:focus { outline: none; border-color: #2a6aaa; }
    
    /* Tag selector */
    .tag-grid { display: flex; flex-wrap: wrap; gap: 6px; margin: 8px 0; }
    .tag-btn { padding: 6px 12px; background: #222; border: 1px solid #333; border-radius: 16px; cursor: pointer; font-size: 12px; color: #aaa; transition: all 0.15s; }
    .tag-btn:hover { border-color: #555; }
    .tag-btn.selected { background: #1a3a2c; border-color: #2a8a5a; color: #5aff9a; }
    
    /* Buttons */
    .btn { display: inline-block; padding: 10px 20px; background: #2a6aaa; color: #fff; border: none; border-radius: 6px; cursor: pointer; font-size: 13px; margin-top: 10px; transition: background 0.15s; }
    .btn:hover { background: #3a7abb; }
    .btn:disabled { background: #333; color: #666; cursor: not-allowed; }
    .btn-danger { background: #8a2a2a; }
    .btn-danger:hover { background: #aa3a3a; }
    .btn-success { background: #2a8a5a; }
    .btn-sm { padding: 6px 12px; font-size: 12px; margin-top: 0; }
    
    /* Status indicators */
    .status { display: inline-block; padding: 3px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; text-transform: uppercase; }
    .status-ok { background: #1a3a2c; color: #5aff9a; }
    .status-err { background: #3a1a1a; color: #ff5a5a; }
    .status-warn { background: #3a3a1a; color: #ffd55a; }
    .status-info { background: #1a2a3a; color: #5ab4ff; }
    
    /* Results */
    .result-box { background: #0a0a0a; border: 1px solid #222; border-radius: 6px; padding: 12px; margin-top: 10px; font-family: 'Consolas', monospace; font-size: 12px; max-height: 300px; overflow-y: auto; white-space: pre-wrap; word-break: break-all; }
    
    /* Log */
    #log { position: fixed; bottom: 0; left: 0; right: 0; background: #0a0a0a; border-top: 1px solid #2a2a2a; padding: 8px 16px; font-size: 11px; font-family: monospace; max-height: 120px; overflow-y: auto; z-index: 100; }
    #log .entry { padding: 2px 0; border-bottom: 1px solid #151515; }
    #log .entry.err { color: #ff5a5a; }
    #log .entry.ok { color: #5aff9a; }
    #log .entry.info { color: #5ab4ff; }
    
    /* Layout helpers */
    .row { display: flex; gap: 10px; align-items: end; }
    .row > * { flex: 1; }
    .mb { margin-bottom: 60px; }
    .mt { margin-top: 12px; }
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
    
    /* Beacon active banner */
    .beacon-banner { background: #1a3a1a; border: 1px solid #2a8a5a; border-radius: 8px; padding: 14px; margin-bottom: 14px; display: none; }
    .beacon-banner.show { display: block; }
    .beacon-id { font-family: monospace; font-size: 11px; color: #5aff9a; word-break: break-all; }
    
    /* QR code style */
    .qr-display { text-align: center; padding: 20px; background: #fff; border-radius: 8px; color: #000; margin: 10px 0; }
    .qr-display .code { font-size: 28px; font-weight: 800; font-family: monospace; letter-spacing: 3px; }
    .qr-display .label { font-size: 11px; color: #666; margin-top: 4px; }
    
    /* Match cards */
    .match-passed { border-left: 3px solid #2a8a5a; }
    .match-shielded { border-left: 3px solid #8a2a2a; opacity: 0.6; }
    .bid-winner { border-left: 3px solid #ffd55a; background: #1a1a0a; }
  </style>
</head>
<body>
  <h1>🎯 Kohedha Beacon — Flow Tester</h1>
  <h2>Test the full API flow: Restaurants → Beacon → Matches → Auction → Deals</h2>
  
  <div class="tabs">
    <div class="tab active" onclick="showPanel('health')">🏥 Health</div>
    <div class="tab" onclick="showPanel('restaurants')">🍽️ Restaurants</div>
    <div class="tab" onclick="showPanel('beacon')">🎯 Beacon</div>
    <div class="tab" onclick="showPanel('matches')">🔍 Matches</div>
    <div class="tab" onclick="showPanel('auction')">⚡ Auction</div>
    <div class="tab" onclick="showPanel('deals')">🎁 Deals</div>
    <div class="tab" onclick="showPanel('noise')">📊 Noise</div>
    <div class="tab" onclick="showPanel('websocket')">🔌 WebSocket</div>
  </div>

  <!-- ═══════════════ HEALTH ═══════════════ -->
  <div id="panel-health" class="panel active">
    <div class="card">
      <div class="card-title">Server Health Check</div>
      <button class="btn" onclick="checkHealth()">Check Health</button>
      <div id="health-result" class="result-box mt" style="display:none"></div>
    </div>
  </div>

  <!-- ═══════════════ RESTAURANTS ═══════════════ -->
  <div id="panel-restaurants" class="panel">
    <div class="card">
      <div class="card-title">Browse Restaurants</div>
      <div class="row">
        <div><label>Latitude</label><input id="r-lat" value="6.9147" /></div>
        <div><label>Longitude</label><input id="r-lng" value="79.8536" /></div>
        <div><label>Radius (km)</label><input id="r-radius" value="10" /></div>
      </div>
      <button class="btn" onclick="loadRestaurants()">Search Nearby</button>
      <button class="btn btn-sm" onclick="loadAllRestaurants()" style="background:#444">Load All</button>
    </div>
    <div id="restaurants-list"></div>
    <div class="card mt">
      <div class="card-title">Vibe Tags</div>
      <button class="btn btn-sm" onclick="loadVibeTags()">Load Tags</button>
      <div id="vibe-tags-list" class="tag-grid mt"></div>
    </div>
  </div>

  <!-- ═══════════════ BEACON ═══════════════ -->
  <div id="panel-beacon" class="panel">
    <div id="beacon-banner" class="beacon-banner">
      <div style="display:flex;justify-content:space-between;align-items:center">
        <div>
          <span class="status status-ok">ACTIVE</span>
          <span id="beacon-timer" style="margin-left:8px;font-size:14px;font-weight:600"></span>
        </div>
        <button class="btn btn-danger btn-sm" onclick="cancelBeacon()">Cancel</button>
      </div>
      <div class="beacon-id mt" id="beacon-id-display"></div>
      <div class="card-meta mt" id="beacon-tags-display"></div>
    </div>
    
    <div class="card" id="beacon-form-card">
      <div class="card-title">Activate Beacon</div>
      <label>User ID</label>
      <input id="b-userId" value="test-user-01" />
      <div class="row">
        <div><label>Latitude</label><input id="b-lat" value="6.9147" /></div>
        <div><label>Longitude</label><input id="b-lng" value="79.8536" /></div>
      </div>
      <label>Select Vibe Tags</label>
      <div id="beacon-tag-selector" class="tag-grid"></div>
      <button class="btn" onclick="activateBeacon()">🎯 Activate Beacon</button>
      <button class="btn btn-sm" onclick="activateTestBeacon()" style="background:#555">Quick Test (30s TTL)</button>
    </div>
    
    <div class="card mt">
      <div class="card-title">Check Existing Beacon</div>
      <div class="row">
        <div><label>User ID</label><input id="check-userId" value="test-user-01" /></div>
        <div style="flex:0"><button class="btn" onclick="checkActiveBeacon()">Check</button></div>
      </div>
      <div id="check-result" class="result-box mt" style="display:none"></div>
    </div>
  </div>

  <!-- ═══════════════ MATCHES ═══════════════ -->
  <div id="panel-matches" class="panel">
    <div class="card">
      <div class="card-title">Find Matches for Beacon</div>
      <div class="row">
        <div><label>Beacon ID</label><input id="m-beaconId" placeholder="Paste beacon ID..." /></div>
        <div style="flex:0"><button class="btn" onclick="findMatches()">Find</button></div>
      </div>
    </div>
    <div id="match-summary" class="card mt" style="display:none">
      <div class="card-title">Match Summary</div>
      <div id="match-summary-content"></div>
    </div>
    <div id="matches-passed"></div>
    <div id="matches-shielded" class="mt"></div>
  </div>

  <!-- ═══════════════ AUCTION ═══════════════ -->
  <div id="panel-auction" class="panel">
    <div class="card">
      <div class="card-title">Run Auction Simulation</div>
      <div class="row">
        <div><label>Beacon ID</label><input id="a-beaconId" placeholder="Paste beacon ID..." /></div>
        <div style="flex:0"><button class="btn" onclick="runAuction()">⚡ Run Auction</button></div>
      </div>
    </div>
    <div id="auction-winner" class="card mt" style="display:none"></div>
    <div id="auction-bids"></div>
  </div>

  <!-- ═══════════════ DEALS ═══════════════ -->
  <div id="panel-deals" class="panel">
    <div class="card">
      <div class="card-title">Create Deal</div>
      <label>Restaurant</label>
      <select id="d-restaurant"><option value="">Loading...</option></select>
      <label>Title</label>
      <input id="d-title" value="30% off cocktails" />
      <label>Description</label>
      <input id="d-desc" value="All signature drinks until closing" />
      <button class="btn" onclick="createDeal()">Create Deal</button>
    </div>
    <div class="card mt">
      <div class="card-title">Active Deals</div>
      <button class="btn btn-sm" onclick="loadDeals()">Refresh</button>
      <div id="deals-list" class="mt"></div>
    </div>
    <div id="claim-result" class="card mt" style="display:none"></div>
  </div>

  <!-- ═══════════════ NOISE ═══════════════ -->
  <div id="panel-noise" class="panel">
    <div class="card">
      <div class="card-title">Consumer Noise State</div>
      <div class="row">
        <div><label>User ID</label><input id="n-userId" value="test-user-01" /></div>
        <div><label>Simulate minutes</label><input id="n-minutes" value="" placeholder="optional" /></div>
        <div style="flex:0"><button class="btn" onclick="checkNoise()">Check</button></div>
      </div>
      <div id="noise-result" class="result-box mt" style="display:none"></div>
    </div>
    <div class="card mt">
      <div class="card-title">Reset Noise</div>
      <div class="row">
        <div><label>User ID</label><input id="nr-userId" value="test-user-01" /></div>
        <div style="flex:0"><button class="btn btn-danger btn-sm" onclick="resetNoise()">Reset</button></div>
      </div>
    </div>
  </div>

  <!-- ═══════════════ WEBSOCKET ═══════════════ -->
  <div id="panel-websocket" class="panel">
    <div class="card">
      <div class="card-title">WebSocket Connection</div>
      <div class="card-meta">Connects to Socket.IO for live beacon events</div>
      <button class="btn" id="ws-connect-btn" onclick="connectWS()">Connect</button>
      <button class="btn btn-danger btn-sm" id="ws-disconnect-btn" onclick="disconnectWS()" style="display:none">Disconnect</button>
      <div class="mt">
        <label>Join Beacon Room</label>
        <div class="row">
          <div><input id="ws-beaconId" placeholder="Beacon ID..." /></div>
          <div style="flex:0"><button class="btn btn-sm" onclick="joinRoom()">Join</button></div>
        </div>
      </div>
    </div>
    <div class="card mt">
      <div class="card-title">Events Log</div>
      <div id="ws-events" class="result-box" style="min-height:150px;max-height:400px"></div>
    </div>
  </div>

  <!-- ═══════════════ ACTIVITY LOG ═══════════════ -->
  <div id="log" class="mb">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">
      <span style="color:#555;font-size:10px">ACTIVITY LOG</span>
      <span style="color:#333;cursor:pointer;font-size:10px" onclick="document.getElementById('log-entries').innerHTML=''">clear</span>
    </div>
    <div id="log-entries"></div>
  </div>

  <script>
    const API = 'http://localhost:3000';
    let activeBeaconId = null;
    let selectedTags = [];
    let wsSocket = null;
    let timerInterval = null;
    let beaconExpiresAt = null;

    // ─── Helpers ───────────────────────
    function log(msg, type = '') {
      const el = document.getElementById('log-entries');
      const d = new Date().toLocaleTimeString();
      el.innerHTML = `<div class="entry ${type}">[${d}] ${msg}</div>` + el.innerHTML;
    }

    async function api(method, path, body) {
      const url = API + path;
      log(`${method} ${path}`, 'info');
      try {
        const opts = { method, headers: { 'Content-Type': 'application/json' } };
        if (body) opts.body = JSON.stringify(body);
        const res = await fetch(url, opts);
        const data = await res.json();
        if (!res.ok) {
          log(`Error ${res.status}: ${data.error || JSON.stringify(data)}`, 'err');
          return null;
        }
        log(`OK ${res.status}`, 'ok');
        return data;
      } catch (e) {
        log(`Network error: ${e.message}`, 'err');
        return null;
      }
    }

    function showPanel(name) {
      document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      document.getElementById('panel-' + name).classList.add('active');
      event.target.classList.add('active');

      // Auto-load data for certain panels
      if (name === 'restaurants') loadVibeTags();
      if (name === 'deals') { loadDeals(); loadRestaurantSelect(); }
      if (name === 'beacon') loadBeaconTags();
      if (name === 'matches' && activeBeaconId) document.getElementById('m-beaconId').value = activeBeaconId;
      if (name === 'auction' && activeBeaconId) document.getElementById('a-beaconId').value = activeBeaconId;
    }

    function showResult(elId, data) {
      const el = document.getElementById(elId);
      el.style.display = 'block';
      el.textContent = JSON.stringify(data, null, 2);
    }

    // ─── Health ────────────────────────
    async function checkHealth() {
      const data = await api('GET', '/health');
      if (data) showResult('health-result', data);
    }

    // ─── Restaurants ───────────────────
    async function loadRestaurants() {
      const lat = document.getElementById('r-lat').value;
      const lng = document.getElementById('r-lng').value;
      const r = document.getElementById('r-radius').value;
      const data = await api('GET', `/api/restaurants?lat=${lat}&lng=${lng}&radiusKm=${r}`);
      if (data) renderRestaurants(data.restaurants);
    }

    async function loadAllRestaurants() {
      const data = await api('GET', '/api/restaurants');
      if (data) renderRestaurants(data.restaurants);
    }

    function renderRestaurants(list) {
      const el = document.getElementById('restaurants-list');
      el.innerHTML = list.map(r => `
        <div class="card">
          <div class="card-title">${r.name}</div>
          <div class="card-meta">
            <span>⭐ ${r.rating}</span>
            ${r.distance_km ? `<span>📍 ${r.distance_km} km</span>` : ''}
            <span>🕐 until ${r.open_until || '?'}</span>
          </div>
          <div class="tag-grid mt">
            ${(r.tags || []).map(t => `<span class="tag-btn">${t}</span>`).join('')}
          </div>
          <div class="card-meta mt" style="font-family:monospace;font-size:10px">${r.id}</div>
        </div>
      `).join('');
    }

    async function loadVibeTags() {
      const data = await api('GET', '/api/vibe-tags');
      if (!data) return;
      const el = document.getElementById('vibe-tags-list');
      el.innerHTML = data.tags.map(t => 
        `<span class="tag-btn">${t.name} <small>(${t.radius_km}km)</small></span>`
      ).join('');
    }

    // ─── Beacon ────────────────────────
    async function loadBeaconTags() {
      const data = await api('GET', '/api/vibe-tags');
      if (!data) return;
      const el = document.getElementById('beacon-tag-selector');
      el.innerHTML = data.tags.map(t => 
        `<div class="tag-btn ${selectedTags.includes(t.name)?'selected':''}" onclick="toggleTag('${t.name}', this)">${t.name}</div>`
      ).join('');
    }

    function toggleTag(name, el) {
      if (selectedTags.includes(name)) {
        selectedTags = selectedTags.filter(t => t !== name);
        el.classList.remove('selected');
      } else {
        selectedTags.push(name);
        el.classList.add('selected');
      }
    }

    async function activateBeacon() {
      if (selectedTags.length === 0) { log('Select at least 1 vibe tag', 'err'); return; }
      const body = {
        userId: document.getElementById('b-userId').value,
        lat: parseFloat(document.getElementById('b-lat').value),
        lng: parseFloat(document.getElementById('b-lng').value),
        vibeTags: selectedTags,
      };
      const data = await api('POST', '/api/beacon/activate', body);
      if (data) {
        activeBeaconId = data.beaconId;
        beaconExpiresAt = new Date(data.expiresAt);
        showBeaconBanner(data);
        log(`Beacon activated: ${data.beaconId}`, 'ok');
      }
    }

    async function activateTestBeacon() {
      if (selectedTags.length === 0) { log('Select at least 1 vibe tag', 'err'); return; }
      const body = {
        userId: document.getElementById('b-userId').value,
        lat: parseFloat(document.getElementById('b-lat').value),
        lng: parseFloat(document.getElementById('b-lng').value),
        vibeTags: selectedTags,
        ttlSeconds: 30,
      };
      const data = await api('POST', '/api/beacon/activate-test', body);
      if (data) {
        activeBeaconId = data.beaconId;
        beaconExpiresAt = new Date(Date.now() + data.expiresInSeconds * 1000);
        showBeaconBanner({ beaconId: data.beaconId, vibeTags: selectedTags, expiresAt: beaconExpiresAt });
        log(`Test beacon activated (${data.expiresInSeconds}s): ${data.beaconId}`, 'ok');
      }
    }

    function showBeaconBanner(data) {
      const banner = document.getElementById('beacon-banner');
      banner.classList.add('show');
      document.getElementById('beacon-id-display').textContent = 'ID: ' + data.beaconId;
      document.getElementById('beacon-tags-display').textContent = 'Tags: ' + (data.vibeTags || selectedTags).join(', ');
      
      if (timerInterval) clearInterval(timerInterval);
      timerInterval = setInterval(() => {
        const remaining = beaconExpiresAt - Date.now();
        if (remaining <= 0) {
          document.getElementById('beacon-timer').textContent = 'EXPIRED';
          clearInterval(timerInterval);
          banner.classList.remove('show');
          activeBeaconId = null;
          return;
        }
        const h = Math.floor(remaining / 3600000);
        const m = Math.floor((remaining % 3600000) / 60000);
        const s = Math.floor((remaining % 60000) / 1000);
        document.getElementById('beacon-timer').textContent = `${h}H ${String(m).padStart(2,'0')}M ${String(s).padStart(2,'0')}S`;
      }, 1000);
    }

    async function cancelBeacon() {
      if (!activeBeaconId) return;
      const userId = document.getElementById('b-userId').value;
      const data = await api('POST', `/api/beacon/${activeBeaconId}/cancel`, { userId });
      if (data) {
        document.getElementById('beacon-banner').classList.remove('show');
        if (timerInterval) clearInterval(timerInterval);
        activeBeaconId = null;
        log('Beacon cancelled', 'ok');
      }
    }

    async function checkActiveBeacon() {
      const userId = document.getElementById('check-userId').value;
      const data = await api('GET', `/api/beacon/active/${userId}`);
      if (data) {
        showResult('check-result', data);
        if (data.active && data.beacon) {
          activeBeaconId = data.beacon.id;
          beaconExpiresAt = new Date(data.beacon.expires_at);
          showBeaconBanner({ beaconId: data.beacon.id, vibeTags: data.beacon.vibe_tags, expiresAt: beaconExpiresAt });
        }
      }
    }

    // ─── Matches ───────────────────────
    async function findMatches() {
      const beaconId = document.getElementById('m-beaconId').value;
      if (!beaconId) { log('Enter a beacon ID', 'err'); return; }
      const data = await api('GET', `/api/beacon/${beaconId}/matches`);
      if (!data) return;

      // Summary
      const summary = document.getElementById('match-summary');
      summary.style.display = 'block';
      document.getElementById('match-summary-content').innerHTML = `
        <div class="card-meta">
          <span>Tags: ${(data.consumerTags||[]).join(', ')}</span>
        </div>
        <div class="grid-2 mt">
          <div><span class="status status-ok">${data.summary.passed} PASSED</span></div>
          <div><span class="status status-err">${data.summary.shielded} SHIELDED</span></div>
        </div>
        ${data.noiseUpdate ? `<div class="mt card-meta">Noise: η=${data.noiseUpdate.level} (${data.noiseUpdate.state})</div>` : ''}
      `;

      // Passed
      document.getElementById('matches-passed').innerHTML = 
        `<div class="card-title mt" style="color:#5aff9a">✅ Passed (${data.passed.length})</div>` +
        data.passed.map(m => `
          <div class="card match-passed">
            <div class="card-title">${m.restaurant}</div>
            <div class="card-meta">
              <span>📍 ${m.distance_km} km</span>
              <span>📶 ψ=${m.signalStrength}</span>
              <span>🎯 J=${m.matchPercent}</span>
              <span>⭐ ${m.rating||'?'}</span>
            </div>
            <div class="tag-grid mt">
              ${(m.matchedTags||[]).map(t => `<span class="tag-btn selected">${t}</span>`).join('')}
              ${(m.restaurantTags||[]).filter(t=>!(m.matchedTags||[]).includes(t)).map(t => `<span class="tag-btn">${t}</span>`).join('')}
            </div>
          </div>
        `).join('');

      // Shielded
      document.getElementById('matches-shielded').innerHTML = 
        `<div class="card-title" style="color:#ff5a5a">🛡️ Vibe Shielded (${data.shielded.length})</div>` +
        data.shielded.map(m => `
          <div class="card match-shielded">
            <div class="card-title">${m.restaurant}</div>
            <div class="card-meta">
              <span>📍 ${m.distance_km} km</span>
              <span>🎯 ${m.matchPercent}</span>
            </div>
          </div>
        `).join('');
    }

    // ─── Auction ───────────────────────
    async function runAuction() {
      const beaconId = document.getElementById('a-beaconId').value;
      if (!beaconId) { log('Enter a beacon ID', 'err'); return; }
      const data = await api('POST', '/api/auction/simulate', { beaconId });
      if (!data) return;

      // Winner
      const winEl = document.getElementById('auction-winner');
      if (data.winner) {
        winEl.style.display = 'block';
        winEl.innerHTML = `
          <div class="card-title" style="color:#ffd55a">🏆 WINNER</div>
          <div style="font-size:16px;font-weight:700;margin:6px 0">${data.winner.restaurant}</div>
          <div class="card-meta">
            <span>📍 ${data.winner.distance_km} km</span>
            <span>🎯 ${data.winner.matchPercent}</span>
            <span>💰 ${data.winner.finalBid} LKR</span>
            <span>⚡ η=${data.winner.efficiencyScore}</span>
          </div>
          <div class="card-meta mt">
            <span>Revenue: Bid ${data.winner.revenue.bidFee} + ${data.winner.revenue.claimFee}</span>
          </div>
        `;
      } else {
        winEl.style.display = 'block';
        winEl.innerHTML = '<div class="card-title" style="color:#ff5a5a">No winner — no eligible restaurants</div>';
      }

      // All bids
      document.getElementById('auction-bids').innerHTML = 
        `<div class="card-title mt">All Bids (${data.eligible}/${data.totalNearby} eligible)</div>` +
        data.bids.map(b => `
          <div class="card ${b.status === 'WINNER' ? 'bid-winner' : ''}">
            <div style="display:flex;justify-content:space-between;align-items:center">
              <div class="card-title">#${b.rank} ${b.restaurant}</div>
              <span class="status ${b.status === 'WINNER' ? 'status-warn' : 'status-info'}">${b.status}</span>
            </div>
            <div class="card-meta">
              <span>📍 ${b.distance_km}km</span>
              <span>🎯 ${b.matchPercent}</span>
              <span>💰 ${b.finalBid} LKR</span>
              <span>⚡ η=${b.efficiencyScore}</span>
              <span>📈 σ=${b.surgeFactor}x</span>
            </div>
          </div>
        `).join('');
    }

    // ─── Deals ─────────────────────────
    async function loadRestaurantSelect() {
      const data = await api('GET', '/api/restaurants');
      if (!data) return;
      const sel = document.getElementById('d-restaurant');
      sel.innerHTML = data.restaurants.map(r => `<option value="${r.id}">${r.name}</option>`).join('');
    }

    async function createDeal() {
      const body = {
        restaurantId: document.getElementById('d-restaurant').value,
        title: document.getElementById('d-title').value,
        description: document.getElementById('d-desc').value,
      };
      const data = await api('POST', '/api/deal/create', body);
      if (data) {
        log(`Deal created: ${data.id}`, 'ok');
        loadDeals();
      }
    }

    async function loadDeals() {
      const data = await api('GET', '/api/deals');
      if (!data) return;
      const el = document.getElementById('deals-list');
      if (data.deals.length === 0) {
        el.innerHTML = '<div class="card-meta">No active deals</div>';
        return;
      }
      el.innerHTML = data.deals.map(d => `
        <div class="card">
          <div class="card-title">${d.title}</div>
          <div class="card-meta">
            <span>🍽️ ${d.restaurant_name}</span>
            <span>🎟️ ${d.claimsRemaining}/${d.total_claims} left</span>
          </div>
          ${d.description ? `<div class="card-meta mt">${d.description}</div>` : ''}
          <button class="btn btn-success btn-sm mt" onclick="claimDeal('${d.id}')">Claim Deal</button>
          <div class="card-meta mt" style="font-family:monospace;font-size:10px">${d.id}</div>
        </div>
      `).join('');
    }

    async function claimDeal(dealId) {
      const userId = document.getElementById('b-userId')?.value || 'test-user-01';
      const data = await api('POST', `/api/deal/${dealId}/claim`, { userId });
      if (!data) return;
      
      const el = document.getElementById('claim-result');
      el.style.display = 'block';
      el.innerHTML = `
        <div class="card-title" style="color:#5aff9a">🎉 Deal Claimed!</div>
        <div class="qr-display">
          <div class="code">${data.claimCode}</div>
          <div class="label">Show this code to restaurant staff</div>
        </div>
        <div class="card-meta">
          <span>🍽️ ${data.restaurant}</span>
          <span>⏱️ Expires: ${data.expiresIn}</span>
        </div>
        <div class="card-meta mt" style="font-style:italic">${data.note}</div>
      `;
      loadDeals(); // refresh list
    }

    // ─── Noise ─────────────────────────
    async function checkNoise() {
      const userId = document.getElementById('n-userId').value;
      const minutes = document.getElementById('n-minutes').value;
      let url = `/api/consumer/${userId}/state`;
      if (minutes) url += `?simulateMinutes=${minutes}`;
      const data = await api('GET', url);
      if (data) {
        const el = document.getElementById('noise-result');
        el.style.display = 'block';
        const statusClass = data.state === 'active' ? 'status-ok' : data.state === 'muted' ? 'status-err' : 'status-warn';
        el.innerHTML = `
<span class="status ${statusClass}">${data.state}</span>
Noise Level: ${data.noiseLevel}
Can Receive Deals: ${data.canReceive ? '✅ Yes' : '❌ No'}

${JSON.stringify(data, null, 2)}`;
      }
    }

    async function resetNoise() {
      const userId = document.getElementById('nr-userId').value;
      const data = await api('POST', `/api/consumer/${userId}/reset`);
      if (data) log(`Noise reset for ${userId}`, 'ok');
    }

    // ─── WebSocket ─────────────────────
    function connectWS() {
      // Load socket.io client dynamically
      if (typeof io === 'undefined') {
        const script = document.createElement('script');
        script.src = 'https://cdn.socket.io/4.7.5/socket.io.min.js';
        script.onload = () => doConnect();
        document.head.appendChild(script);
      } else {
        doConnect();
      }
    }

    function doConnect() {
      wsSocket = io(API);
      wsSocket.on('connect', () => {
        wsLog('Connected: ' + wsSocket.id, 'ok');
        document.getElementById('ws-connect-btn').style.display = 'none';
        document.getElementById('ws-disconnect-btn').style.display = 'inline-block';
        
        // Auto-join user room for current user
        const userId = document.getElementById('b-userId')?.value || 'test-user-01';
        wsSocket.emit('join:user', userId);
        wsLog('Joined user room: ' + userId, 'info');
      });
      wsSocket.on('disconnect', () => {
        wsLog('Disconnected', 'err');
        document.getElementById('ws-connect-btn').style.display = 'inline-block';
        document.getElementById('ws-disconnect-btn').style.display = 'none';
      });
      
      // Beacon events
      wsSocket.on('beacon:activated', (data) => {
        wsLog('Beacon activated: ' + data.beaconId, 'ok');
      });
      wsSocket.on('beacon:countdown', (data) => {
        wsLog('Countdown: ' + data.display, 'info');
      });
      wsSocket.on('beacon:expired', (data) => {
        wsLog('Beacon expired: ' + data.beaconId, 'warn');
      });
      
      // DEAL EVENTS - Show popup when deal is created!
      wsSocket.on('deal:created', (data) => {
        wsLog('🎉 DEAL CREATED: ' + data.deal.restaurant, 'ok');
        showDealPopup(data.deal);
      });
      
      wsSocket.on('deal:none', (data) => {
        wsLog('No deals available: ' + data.message, 'warn');
        showNoDealPopup(data.message);
      });
    }

    function disconnectWS() {
      if (wsSocket) {
        wsSocket.disconnect();
        wsSocket = null;
      }
    }

    function joinRoom() {
      const beaconId = document.getElementById('ws-beaconId').value;
      if (!beaconId || !wsSocket) return;
      wsSocket.emit('join:beacon', beaconId);
      wsLog('Joined beacon room: ' + beaconId, 'info');
    }

    function wsLog(msg, type = '') {
      const el = document.getElementById('ws-events');
      const d = new Date().toLocaleTimeString();
      el.innerHTML = `<div class="entry ${type}">[${d}] ${msg}</div>` + el.innerHTML;
    }

    // ─── Deal Popup (Real-time notification) ───
    function showDealPopup(deal) {
      // Create popup overlay
      const popup = document.createElement('div');
      popup.id = 'deal-popup';
      popup.style.cssText = `
        position: fixed; top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.85); z-index: 1000;
        display: flex; align-items: center; justify-content: center;
        animation: fadeIn 0.3s ease-in;
      `;
      
      popup.innerHTML = `
        <div style="background:#1a1a1a; border:2px solid #2a8a5a; border-radius:12px; padding:24px; max-width:400px; width:90%; box-shadow: 0 8px 32px rgba(0,0,0,0.5); animation: slideUp 0.3s ease-out;">
          <div style="text-align:center; margin-bottom:16px; font-size:48px;">🎉</div>
          <div style="font-size:20px; font-weight:700; color:#5aff9a; text-align:center; margin-bottom:8px;">
            Deal Found!
          </div>
          <div style="font-size:16px; font-weight:600; color:#fff; text-align:center; margin-bottom:12px;">
            ${deal.restaurant}
          </div>
          <div style="background:#0a0a0a; border-radius:8px; padding:14px; margin-bottom:14px;">
            <div style="font-size:15px; color:#fff; margin-bottom:6px;">${deal.title}</div>
            <div style="font-size:13px; color:#888;">${deal.description}</div>
          </div>
          <div style="display:flex; gap:12px; font-size:12px; color:#888; margin-bottom:18px; flex-wrap:wrap;">
            <span>📍 ${deal.distance_km}km</span>
            <span>🎯 ${deal.matchPercent} match</span>
            <span>🎟️ ${deal.claimsRemaining} available</span>
          </div>
          <button onclick="claimDealFromPopup('${deal.id}')" class="btn btn-success" style="width:100%; margin:0; padding:14px; font-size:15px;">
            Claim This Deal
          </button>
          <button onclick="closePopup()" class="btn" style="width:100%; margin-top:8px; background:#333;">
            Maybe Later
          </button>
        </div>
      `;
      
      document.body.appendChild(popup);
      
      // Add animations
      const style = document.createElement('style');
      style.textContent = `
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        @keyframes slideUp { from { transform: translateY(30px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
      `;
      document.head.appendChild(style);
    }

    function showNoDealPopup(message) {
      const popup = document.createElement('div');
      popup.id = 'deal-popup';
      popup.style.cssText = `
        position: fixed; top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.85); z-index: 1000;
        display: flex; align-items: center; justify-content: center;
        animation: fadeIn 0.3s ease-in;
      `;
      
      popup.innerHTML = `
        <div style="background:#1a1a1a; border:2px solid #8a2a2a; border-radius:12px; padding:24px; max-width:400px; width:90%; box-shadow: 0 8px 32px rgba(0,0,0,0.5); animation: slideUp 0.3s ease-out;">
          <div style="text-align:center; margin-bottom:16px; font-size:48px;">😔</div>
          <div style="font-size:20px; font-weight:700; color:#ff5a5a; text-align:center; margin-bottom:12px;">
            No Deals Available
          </div>
          <div style="font-size:14px; color:#aaa; text-align:center; margin-bottom:20px;">
            ${message || 'No restaurants matched your vibe preferences at this time.'}
          </div>
          <button onclick="closePopup()" class="btn" style="width:100%; margin:0;">
            OK
          </button>
        </div>
      `;
      
      document.body.appendChild(popup);
    }

    async function claimDealFromPopup(dealId) {
      const userId = document.getElementById('b-userId')?.value || 'test-user-01';
      const data = await api('POST', `/api/deal/${dealId}/claim`, { userId });
      if (data) {
        closePopup();
        
        // Show claim result in a new popup
        const popup = document.createElement('div');
        popup.id = 'claim-popup';
        popup.style.cssText = `
          position: fixed; top: 0; left: 0; right: 0; bottom: 0;
          background: rgba(0,0,0,0.85); z-index: 1000;
          display: flex; align-items: center; justify-content: center;
        `;
        
        popup.innerHTML = `
          <div style="background:#1a1a1a; border:2px solid #2a8a5a; border-radius:12px; padding:24px; max-width:400px; width:90%; box-shadow: 0 8px 32px rgba(0,0,0,0.5);">
            <div style="text-align:center; margin-bottom:16px; font-size:48px;">✅</div>
            <div style="font-size:20px; font-weight:700; color:#5aff9a; text-align:center; margin-bottom:16px;">
              Deal Claimed!
            </div>
            <div class="qr-display">
              <div class="code">${data.claimCode}</div>
              <div class="label">Show this code to restaurant staff</div>
            </div>
            <div style="font-size:14px; color:#888; text-align:center; margin-top:12px;">
              🍽️ ${data.restaurant}<br>
              ⏱️ Expires: ${data.expiresIn}
            </div>
            <button onclick="closeClaimPopup()" class="btn btn-success" style="width:100%; margin-top:16px;">
              Got It!
            </button>
          </div>
        `;
        
        document.body.appendChild(popup);
      }
    }

    function closePopup() {
      const popup = document.getElementById('deal-popup');
      if (popup) popup.remove();
    }

    function closeClaimPopup() {
      const popup = document.getElementById('claim-popup');
      if (popup) popup.remove();
    }

    // Auto-connect WebSocket on page load
    window.addEventListener('load', () => {
      setTimeout(() => {
        connectWS();
      }, 500);
    });  wsLog('Disconnected', 'err');
        document.getElementById('ws-connect-btn').style.display = 'inline-block';
        document.getElementById('ws-disconnect-btn').style.display = 'none';
      });
      wsSocket.on('beacon:activated', d => wsLog('beacon:activated → ' + JSON.stringify(d), 'ok'));
      wsSocket.on('beacon:countdown', d => wsLog('beacon:countdown → ' + d.display, 'info'));
      wsSocket.on('beacon:expired', d => wsLog('beacon:expired → ' + JSON.stringify(d), 'err'));
      wsSocket.on('beacon:cancelled', d => wsLog('beacon:cancelled → ' + JSON.stringify(d), 'err'));
    }

    function disconnectWS() {
      if (wsSocket) wsSocket.disconnect();
    }

    function joinRoom() {
      const beaconId = document.getElementById('ws-beaconId').value;
      if (!beaconId || !wsSocket) return;
      wsSocket.emit('join:beacon', beaconId);
      wsLog('Joined room: beacon:' + beaconId, 'info');
    }

    function wsLog(msg, type = '') {
      const el = document.getElementById('ws-events');
      const d = new Date().toLocaleTimeString();
      el.innerHTML += `<div class="entry ${type}">[${d}] ${msg}</div>`;
      el.scrollTop = el.scrollHeight;
      log('WS: ' + msg, type);
    }

    // ─── Init ──────────────────────────
    log('Frontend loaded. Backend expected at ' + API, 'info');
    checkHealth();
  </script>
</body>
</html>
